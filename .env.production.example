# Production Environment Variables for BigFlavor Band Agent
# Copy this file to .env.production and fill in your actual values

# ============================================================================
# Backend Trust Boundary
# ============================================================================
# Shared secret the Next.js BFF presents to the FastAPI backend on protected
# routes. Generate a strong random value (e.g. `openssl rand -hex 32`) and keep
# it identical for the backend and frontend services.
BACKEND_API_SECRET=your_backend_api_secret_here

# ============================================================================
# Application environment
# ============================================================================
# Leave unset (or set to anything other than "development") in production. The
# backend then REQUIRES a real DB password and fails fast instead of falling
# back to the insecure dev default.
APP_ENV=production

# ============================================================================
# Database Configuration
# ============================================================================
# Required in production. POSTGRES_PASSWORD also flows in as DB_PASSWORD via
# docker-compose; the backend will refuse to start if it is missing.
POSTGRES_PASSWORD=your_secure_database_password_here

# ============================================================================
# LLM Configuration
# ============================================================================
# LLM Provider: 'anthropic' or 'ollama'
# - anthropic: Uses Claude API (costs money, best quality)
# - ollama: Uses local LLM (free, lower quality, requires more resources)
LLM_PROVIDER=ollama

# Anthropic API (only required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ollama Configuration (only used if LLM_PROVIDER=ollama)
# Base URL for Ollama service (use http://ollama:11434 in Docker)
OLLAMA_BASE_URL=http://ollama:11434
# Model to use. The deploy script pulls this automatically when LLM_PROVIDER=ollama.
# Recommended on a 24GB GPU (RTX 3090): qwen2.5:14b — best tool-calling reliability
# for the agent. Lighter option: qwen2.5:7b. Max quality (tight on 24GB): qwen2.5:32b.
# See https://ollama.com/library for all available models.
OLLAMA_MODEL=qwen2.5:14b

# ============================================================================
# Google OAuth Configuration
# ============================================================================
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials

# Google OAuth Client ID
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Google OAuth Client Secret
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================================================
# Application Configuration
# ============================================================================
NODE_ENV=production

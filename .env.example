# API Keys - Copy this file to .env and add your actual keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
VOYAGE_API_KEY=your_voyage_api_key_here

# Backend trust boundary
# Shared secret the Next.js BFF presents to the FastAPI backend on protected
# routes. Generate a random value (e.g. `openssl rand -hex 32`). Must match
# between the backend and frontend services.
BACKEND_API_SECRET=your_backend_api_secret_here

# Application environment.
# Set to "development" to allow DatabaseManager's dev password default when
# DB_PASSWORD is unset. Any other value (or unset) requires a real DB_PASSWORD
# and the backend will fail fast if it is missing.
APP_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bigflavor
DB_USER=bigflavor
DB_PASSWORD=your_database_password_here

# Frontend Development Dockerfile - Next.js with hot reloading
FROM node:20-alpine
WORKDIR /app

# Copy package files
COPY package*.json ./
RUN npm ci --legacy-peer-deps

# Copy source code (will be overridden by volume mounts)
COPY . ./

ENV NODE_ENV development
ENV PORT 3000
ENV HOSTNAME "0.0.0.0"

EXPOSE 3000

# Run in development mode with hot reloading
CMD ["npm", "run", "dev"]

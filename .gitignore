# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Anchored to repo root so this Python-venv pattern does not swallow frontend/lib/
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# Node (stray installs anywhere in the repo; frontend has its own anchored rule)
node_modules/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Environment variables
.env
.env.local
.env.production

# Cache
.cache/
*.cache
.audio_cache/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Project specific
song_cache.json
*.db
*.sqlite

# Temporary audio files (but keep audio_library/)
temp_audio/

# Audio library - MP3s are kept locally but not in git (too large)
audio_library/*.mp3
audio_library/*.wav
audio_library/*.flac

# Auto-clean output dir (runtime-generated, host-side writable mount)
audio_library/produced/

# Database
sql/init/*.sql.bak
postgres_data/

# Runtime-generated radio playlist (written by backend write_playlist_file())
streaming/playlist/radio.m3u

# Local Claude Code settings (machine-specific permission allowlist)
.claude/settings.local.json

# Local Compose override (machine-specific dev setup).
# Tracked template lives at docker-compose.override.yml.example — copy it to use.
docker-compose.override.yml

# Serena MCP local tool state (machine-specific; its own nested .gitignore
# doesn't cover memories/ or project.yml, which was tripping the
# release-manager's dirty-working-tree guard)
.serena/
